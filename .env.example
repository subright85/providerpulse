# Supabase (subscribers + community reports)
# Create a project at https://supabase.com, run supabase/init.sql in SQL editor,
# then copy these from the project's API settings.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...

# Resend (email alerts) — used by scripts/monitor.mjs only, not the client.
# Free tier: 100 emails/day. Sign up at https://resend.com.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=alerts@providerpulse.dev

# Telegram (existing — used by monitor.mjs)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Supabase service role (used by monitor.mjs for cross-user reads)
SUPABASE_SERVICE_KEY=eyJhbGc...
